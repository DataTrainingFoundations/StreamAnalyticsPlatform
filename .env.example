AIRNOW_API_KEY=
AIRNOW_DATA_URL="https://www.airnowapi.org/aq/data/"

DOCKER_ENV=1
DEV=1

KAFKA_PRODUCER_LINGER_MS="100"
KAFKA_PRODUCER_BATCH_SIZE="262144"
KAFKA_PRODUCER_COMRESSION_TYPE="snappy"
KAFKA_PRODUCER_ACKS="all"
KAFKA_PRODUCER_RETRIES="10"
KAFKA_PRODUCER_ENABLE_IDEMPOTENCE="1"
KAFKA_PRODUCER_BUFFER_MEMORY="67108864"

MAX_KAFKA_CONSUMER_IDLE_TIME="30"
LANDING_FLUSH_RECORD_COUNT="25000"
KAFKA_CONSUMER_MAX_POLL_RECORDS="25000"
KAFKA_CONSUMER_FETCH_MAX_WAIT_MS="500"
KAFKA_CONSUMER_FETCH_MIN_BYTES="1024"

DOCKER_KAFKA_BOOTSTRAP_SERVER="kafka:9092"
LOCAL_KAFKA_BOOTSTRAP_SERVER="localhost:9094"
RAW_HISTORIC_DATA_KAFKA_TOPIC="airnow_raw_historical"
RAW_CURRENT_DATA_KAFKA_TOPIC="airnow_raw_current"

AWS_ENDPOINT= "s3.amazonaws.com"
AWS_USER=
AWS_PASSWORD=
AWS_REGION_NAME="us-east-1"

STREAMFLOW_BUCKET= "stream-analytics-project-bucket"
STREAMFLOW_BUCKET_PROGRESS_KEY = "backfill_progress.json"
STREAMFLOW_BUCKET_ARCHIVE_PREFIX="archive/airnow/"
STREAMFLOW_BUCKET_LANDING_PREFIX="landing/airnow/"

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB="airflow"

AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=
_AIRFLOW_WWW_USER_USERNAME=
_AIRFLOW_WWW_USER_PASSWORD=

DOCKER_SPARK_MASTER="spark://spark-master:7077"
